{
  "name": "omni-router",
  "version": "1.0.0",
  "description": "Production-grade AI Model Routing Engine with React + TypeScript testing interface",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ui": "jest --testPathPattern=ui",
    "lint": "eslint src/**/*.ts*",
    "start": "node dist/server.js",
    "dev": "concurrently \"npm run build -- --watch\" \"nodemon dist/server.js\"",
    "frontend": "vite preview --port 3000"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "express": "^4.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "nodemon": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "keywords": [
    "ai",
    "model-routing",
    "llm",
    "router",
    "react",
    "typescript"
  ],
  "license": "MIT"
}
